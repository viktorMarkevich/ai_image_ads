<%= form_with(model: context) do |form| %>
  <% if context.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(context.errors.count, "error") %> prohibited this context from being saved:</h2>

      <ul>
        <% context.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, style: "display: block" %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :industry_description, style: "display: block" %>
    <%= form.text_field :industry_description %>
  </div>

  <div>
    <%= form.label :landing_page_url, style: "display: block" %>
    <%= form.text_field :landing_page_url %>
  </div>

  <div>
    <%= form.label :tiktok_ad_account_id, style: "display: block" %>
    <%= form.text_field :tiktok_ad_account_id %>
  </div>

  <div>
    <%= form.label :tiktok_campaign_id, style: "display: block" %>
    <%= form.text_field :tiktok_campaign_id %>
  </div>

  <div>
    <%= form.label :tiktok_adgroup_id, style: "display: block" %>
    <%= form.text_field :tiktok_adgroup_id %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
